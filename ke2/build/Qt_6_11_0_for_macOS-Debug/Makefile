ke2.app/Contents/PkgInfo: 
	@test -d ke2.app/Contents || mkdir -p ke2.app/Contents
	@$(DEL_FILE) ke2.app/Contents/PkgInfo
	@echo "APPL????" > ke2.app/Contents/PkgInfo
ke2.app/Contents/Info.plist: 
	@test -d ke2.app/Contents || mkdir -p ke2.app/Contents
	@$(DEL_FILE) ke2.app/Contents/Info.plist
	@set -o pipefail && plutil -convert xml1 -o - /Users/ddd/Qt/6.11.0/macos/mkspecs/macx-clang/Info.plist.app | sed -e "s,@SHORT_VERSION@,1.0,g" -e "s,\$${QMAKE_SHORT_VERSION},1.0,g" -e "s,@FULL_VERSION@,1.0.0,g" -e "s,\$${QMAKE_FULL_VERSION},1.0.0,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" -e "s,@BUNDLEIDENTIFIER@,com.yourcompany.ke2,g" -e "s,\$${PRODUCT_BUNDLE_IDENTIFIER},com.yourcompany.ke2,g" -e "s,\$${MACOSX_DEPLOYMENT_TARGET},13,g" -e "s,\$${IPHONEOS_DEPLOYMENT_TARGET},,g" -e "s,\$${TVOS_DEPLOYMENT_TARGET},,g" -e "s,\$${WATCHOS_DEPLOYMENT_TARGET},,g" -e "s,\$${IOS_LAUNCH_SCREEN},LaunchScreen,g" -e "s,@ICON@,,g" -e "s,\$${ASSETCATALOG_COMPILER_APPICON_NAME},,g" -e "s,@EXECUTABLE@,ke2,g" -e "s,@LIBRARY@,ke2,g" -e "s,\$${EXECUTABLE_NAME},ke2,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" >ke2.app/Contents/Info.plist

all: Makefile \
		ke2.app/Contents/PkgInfo \
		ke2.app/Contents/Info.plist ke2.app/Contents/MacOS/ke2

dist: distdir FORCE
	(cd `dirname $(DISTDIR)` && $(TAR) $(DISTNAME).tar $(DISTNAME) && $(COMPRESS) $(DISTNAME).tar) && $(MOVE) `dirname $(DISTDIR)`/$(DISTNAME).tar.gz . && $(DEL_FILE) -r $(DISTDIR)

distdir: FORCE
	@test -d $(DISTDIR) || mkdir -p $(DISTDIR)
	$(COPY_FILE) --parents $(DIST) $(DISTDIR)/
	$(COPY_FILE) --parents ../../AnnotationView.h ../../DatabaseManager.h ../../mainwindow.h $(DISTDIR)/
	$(COPY_FILE) --parents ../../AnnotationView.cpp ../../main.cpp ../../mainwindow.cpp $(DISTDIR)/
	$(COPY_FILE) --parents ../../mainwindow.ui $(DISTDIR)/


clean: compiler_clean 
	-$(DEL_FILE) $(OBJECTS)
	-$(DEL_FILE) *~ core *.core


distclean: clean 
	-$(DEL_FILE) -r ke2.app
	-$(DEL_FILE) .qmake.stash
	-$(DEL_FILE) Makefile


