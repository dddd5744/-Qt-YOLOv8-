####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/opt/ke2/bin || mkdir -p $(INSTALL_ROOT)/opt/ke2/bin
	$(DEL_FILE) -r $(INSTALL_ROOT)/opt/ke2/bin/ke2.app
	
	$(QINSTALL) ke2.app $(INSTALL_ROOT)/opt/ke2/bin/ke2.app

uninstall_target: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/opt/ke2/bin/ke2.app
	-$(DEL_DIR) $(INSTALL_ROOT)/opt/ke2/bin/ 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

FORCE:

